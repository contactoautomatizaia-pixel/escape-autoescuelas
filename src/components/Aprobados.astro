---
const WHATSAPP_URL = "https://wa.me/34601302309?text=Hola%2C%20quiero%20info%20de%20Escape%20Autoescuelas";

const aprobados = [
  { img: "/assets/aprobados/aprobado-01.webp", nombre: "Paula, Miguel, Sergio y Luis", permiso: "Permiso B",  fecha: "Mar 2024" },
  { img: "/assets/aprobados/aprobado-02.webp", nombre: "Julia y Cinthia",               permiso: "Permiso B",  fecha: "Abr 2026" },
  { img: "/assets/aprobados/aprobado-03.webp", nombre: "Pau y Carlos",                  permiso: "Permiso B",  fecha: "Mar 2026" },
  { img: "/assets/aprobados/aprobado-04.webp", nombre: "Alberto e Ismael",              permiso: "Permiso B",  fecha: "Mar 2026" },
  { img: "/assets/aprobados/aprobado-05.webp", nombre: "Claudia",                        permiso: "Permiso B",  fecha: "Mar 2026" },
  { img: "/assets/aprobados/aprobado-06.webp", nombre: "Sergio y Flifla",               permiso: "Permiso B",  fecha: "Feb 2026" },
  { img: "/assets/aprobados/aprobado-07.webp", nombre: "Pau",                            permiso: "Permiso B",  fecha: "Abr 2026" },
  { img: "/assets/aprobados/aprobado-08.webp", nombre: "Carlos y Rosa",                  permiso: "Permiso B",  fecha: "Mar 2026" },
  { img: "/assets/aprobados/aprobado-09.webp", nombre: "Jaouad, Marina, Marcel y Tulio", permiso: "Permiso B",  fecha: "Abr 2026" },
  { img: "/assets/aprobados/aprobado-10.webp", nombre: "Carlos",                          permiso: "Permiso B",  fecha: "Feb 2022" },
  { img: "/assets/aprobados/aprobado-11.webp", nombre: "Leonel, Rafa y Lara",            permiso: "Permiso B",  fecha: "Ene 2023" },
  { img: "/assets/aprobados/aprobado-12.webp", nombre: "Maya e Inés",                    permiso: "Permiso B",  fecha: "Feb 2025" },
  { img: "/assets/aprobados/aprobado-13.webp", nombre: "Andrea Palazón",                 permiso: "Permiso B",  fecha: "Ene 2022" },
  { img: "/assets/aprobados/aprobado-14.webp", nombre: "Andreas, Jaime, Aarón y Valeria", permiso: "B · A2",   fecha: "Oct 2025" },
  { img: "/assets/aprobados/aprobado-15.webp", nombre: "Etel, David, Michael y Arturo",  permiso: "Permiso B",  fecha: "Sep 2025" },
  { img: "/assets/aprobados/aprobado-16.webp", nombre: "Iván, Jaime y Soraya",           permiso: "Permiso B",  fecha: "Mar 2025" },
  { img: "/assets/aprobados/aprobado-17.webp", nombre: "Alma y Mario",                   permiso: "Permiso B",  fecha: "Feb 2026" },
  { img: "/assets/aprobados/aprobado-18.webp", nombre: "Hugo, Álvaro y Siarhei",         permiso: "Permiso B",  fecha: "Ene 2026" },
  { img: "/assets/aprobados/aprobado-19.webp", nombre: "Lucía, Aarón y Elías",           permiso: "Permiso B",  fecha: "Mar 2026" },
];

const mid = Math.ceil(aprobados.length / 2);
const row1 = aprobados.slice(0, mid);   // 10 fotos → izquierda
const row2 = aprobados.slice(mid);      //  9 fotos → derecha
---

<section id="aprobados" style="padding:96px 0;background:var(--escape-ink);color:#fff;overflow:hidden;" data-c="aprobadosSection">

  <!-- ── Cabecera ── -->
  <div
    class="escape-reveal aprobados-header"
    style="padding:0 56px;margin-bottom:64px;display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:24px;"
  >
    <div>
      <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.15em;color:var(--escape-red);margin-bottom:16px;display:flex;align-items:center;gap:10px;">
        <span style="width:20px;height:1px;background:var(--escape-red);display:inline-block;"></span>
        APROBADOS
      </div>
      <h2 style="font-family:var(--font-display);font-size:clamp(56px,7vw,96px);line-height:0.95;letter-spacing:-0.045em;color:#fff;margin:0;">
        Cada L<br/>tiene nombre.
      </h2>
      <p style="font-size:17px;line-height:1.55;color:rgba(255,255,255,0.5);margin-top:20px;max-width:480px;">
        Más de 500 alumnos formados desde 2011.<br/>Personas reales, con carnet en la mano.
      </p>
    </div>

    <a
      href={WHATSAPP_URL}
      target="_blank"
      rel="noopener"
      class="aprobados-cta"
      aria-label="Contactar por WhatsApp"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.15-.174.2-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
      </svg>
      ¿Quieres ser el siguiente?
    </a>
  </div>

  <!-- ── Carrusel ── -->
  <div class="carousel-viewport">

    <!-- Fade izquierdo -->
    <div class="carousel-fade carousel-fade-left" aria-hidden="true"></div>
    <!-- Fade derecho -->
    <div class="carousel-fade carousel-fade-right" aria-hidden="true"></div>

    <!-- Fila 1 → izquierda -->
    <div class="carousel-row" id="row1">
      <div class="carousel-track track-left">
        {[...row1, ...row1].map((a, i) => (
          <article class="ap-card" aria-label={`${a.nombre} · ${a.permiso} · ${a.fecha}`}>
            <img
              src={a.img}
              alt={`${a.nombre} aprobó el ${a.permiso} en Escape Autoescuelas`}
              loading="lazy"
              width="480"
              height="640"
              draggable="false"
            />
            <!-- Gradiente base -->
            <div class="ap-grad" aria-hidden="true"></div>
            <!-- Gloss hover -->
            <div class="ap-gloss" aria-hidden="true"></div>
            <!-- Badge aprobado -->
            <div class="ap-badge" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              APROBADO
            </div>
            <!-- Info -->
            <div class="ap-info">
              <div class="ap-permiso">{a.permiso}</div>
              <div class={`ap-nombre${a.nombre.length > 22 ? " ap-nombre-sm" : ""}`}>{a.nombre}</div>
              <div class="ap-fecha">{a.fecha}</div>
            </div>
          </article>
        ))}
      </div>
    </div>

    <!-- Fila 2 → derecha -->
    <div class="carousel-row" id="row2" style="margin-top:14px;">
      <div class="carousel-track track-right">
        {[...row2, ...row2].map((a, i) => (
          <article class="ap-card" aria-label={`${a.nombre} · ${a.permiso} · ${a.fecha}`}>
            <img
              src={a.img}
              alt={`${a.nombre} aprobó el ${a.permiso} en Escape Autoescuelas`}
              loading="lazy"
              width="480"
              height="640"
              draggable="false"
            />
            <div class="ap-grad" aria-hidden="true"></div>
            <div class="ap-gloss" aria-hidden="true"></div>
            <div class="ap-badge" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              APROBADO
            </div>
            <div class="ap-info">
              <div class="ap-permiso">{a.permiso}</div>
              <div class={`ap-nombre${a.nombre.length > 22 ? " ap-nombre-sm" : ""}`}>{a.nombre}</div>
              <div class="ap-fecha">{a.fecha}</div>
            </div>
          </article>
        ))}
      </div>
    </div>

  </div><!-- /carousel-viewport -->

</section>

<style>
  /* ── Viewport ── */
  .carousel-viewport {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  /* ── Fades laterales ── */
  .carousel-fade {
    position: absolute;
    top: 0; bottom: 0;
    width: 180px;
    z-index: 10;
    pointer-events: none;
  }
  .carousel-fade-left  { left: 0;  background: linear-gradient(to right, var(--escape-ink) 0%, transparent 100%); }
  .carousel-fade-right { right: 0; background: linear-gradient(to left,  var(--escape-ink) 0%, transparent 100%); }

  /* ── Filas ── */
  .carousel-row { width: 100%; overflow: hidden; }

  /* ── Track ── */
  .carousel-track {
    display: flex;
    gap: 14px;
    width: max-content;
    will-change: transform;
  }
  .track-left  { animation: scrollLeft  38s linear infinite; }
  .track-right { animation: scrollRight 42s linear infinite; }

  /* Pausa al hacer hover sobre la fila */
  .carousel-row:hover .carousel-track { animation-play-state: paused; }

  /* ── Keyframes ── */
  @keyframes scrollLeft {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @keyframes scrollRight {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }

  /* ── Tarjeta ── */
  .ap-card {
    position: relative;
    width: 240px;
    height: 320px;
    border-radius: 16px;
    overflow: hidden;
    flex-shrink: 0;
    cursor: pointer;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    /* Perspectiva 3D */
    transform-style: preserve-3d;
    transition:
      transform 0.45s cubic-bezier(0.22,1,0.36,1),
      box-shadow 0.45s cubic-bezier(0.22,1,0.36,1),
      border-color 0.35s;
  }
  .ap-card:hover {
    transform: translateY(-10px) scale(1.04);
    box-shadow:
      0 30px 64px -12px rgba(0,0,0,0.7),
      0 0 0 1px rgba(200,16,46,0.45),
      0 0 32px -8px rgba(200,16,46,0.3);
    border-color: rgba(200,16,46,0.4);
    z-index: 5;
  }

  /* ── Imagen ── */
  .ap-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.6s cubic-bezier(0.22,1,0.36,1);
    user-select: none;
  }
  .ap-card:hover img { transform: scale(1.06); }

  /* ── Gradiente base ── */
  .ap-grad {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.92) 0%,
      rgba(0,0,0,0.3)  50%,
      transparent       100%
    );
    pointer-events: none;
    transition: opacity 0.4s;
  }

  /* ── Gloss (brillo diagonal en hover) ── */
  .ap-gloss {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(255,255,255,0.12) 0%,
      transparent 50%,
      transparent 100%
    );
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.45s;
  }
  .ap-card:hover .ap-gloss { opacity: 1; }

  /* ── Badge APROBADO ── */
  .ap-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(200,16,46,0.9);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: #fff;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    font-weight: 700;
    padding: 5px 9px;
    border-radius: 999px;
    display: flex;
    align-items: center;
    gap: 5px;
    opacity: 0;
    transform: translateY(-6px) scale(0.9);
    transition:
      opacity  0.35s cubic-bezier(0.22,1,0.36,1),
      transform 0.35s cubic-bezier(0.22,1,0.36,1);
    pointer-events: none;
  }
  .ap-card:hover .ap-badge {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  /* ── Info inferior ── */
  .ap-info {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 20px 18px 18px;
    transform: translateY(6px);
    transition: transform 0.4s cubic-bezier(0.22,1,0.36,1);
  }
  .ap-card:hover .ap-info { transform: translateY(0); }

  .ap-permiso {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.16em;
    color: var(--escape-red);
    background: rgba(200,16,46,0.18);
    border: 1px solid rgba(200,16,46,0.35);
    display: inline-block;
    padding: 3px 9px;
    border-radius: 999px;
    margin-bottom: 7px;
  }
  .ap-nombre {
    font-family: var(--font-display);
    font-size: 20px;
    letter-spacing: -0.02em;
    color: #fff;
    line-height: 1.1;
  }
  .ap-nombre-sm { font-size: 14px; }
  .ap-fecha {
    font-family: var(--font-mono);
    font-size: 10px;
    color: rgba(255,255,255,0.4);
    margin-top: 5px;
  }

  /* ── Línea roja decorativa debajo de la sección ── */
  #aprobados::after {
    content: '';
    display: block;
    width: 64px;
    height: 3px;
    background: var(--escape-red);
    margin: 64px auto 0;
    border-radius: 999px;
    opacity: 0.5;
  }

  /* ── CTA button ── */
  .aprobados-cta {
    background: #25D366;
    color: #fff;
    padding: 16px 26px;
    border-radius: 999px;
    font-weight: 700;
    font-size: 15px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
    transition: transform 0.3s cubic-bezier(0.22,1,0.36,1), box-shadow 0.3s;
  }
  .aprobados-cta:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px -6px rgba(37,211,102,0.45);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .aprobados-header { padding: 0 24px !important; }
    .carousel-fade    { width: 60px; }
    .ap-card          { width: 180px; height: 240px; }
    #aprobados        { padding: 64px 0 !important; }
  }

  /* Respeta preferencia de movimiento reducido */
  @media (prefers-reduced-motion: reduce) {
    .carousel-track { animation: none !important; }
  }
</style>
