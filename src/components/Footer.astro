---
import { siteConfig } from "../config/site";

const words = ["En", "Elx,", "los", "que", "aprueban", "eligen", "Escape."];
---

<footer
  style="background:var(--escape-ink);color:#fff;padding:80px 56px 32px;overflow:hidden;position:relative;"
  data-c="footer"
  id="site-footer"
>
  <!-- Slogan con word-mask reveal -->
  <div style="margin-bottom:64px;overflow:hidden;" id="footer-slogan-wrap">
    <div style="display:flex;flex-wrap:wrap;gap:0 18px;font-family:var(--font-display);font-size:clamp(40px,6vw,88px);line-height:1;letter-spacing:-0.04em;">
      {words.map((w, i) => (
        <div style="overflow:hidden;display:inline-block;">
          <span
            class="footer-word"
            style={`display:inline-block;transform:translateY(110%);opacity:0;transition:transform 0.7s cubic-bezier(0.22,1,0.36,1),opacity 0.7s ease;transition-delay:${i * 80}ms;color:${w === "Escape." ? "var(--escape-red)" : "#fff"};`}
          >{w}</span>
        </div>
      ))}
    </div>
    <div style="overflow:hidden;margin-top:16px;">
      <div class="footer-line" style="height:1px;background:rgba(255,255,255,0.15);transform:scaleX(0);transform-origin:left;transition:transform 1s cubic-bezier(0.22,1,0.36,1);transition-delay:560ms;"></div>
    </div>
  </div>

  <!-- Columnas info -->
  <div style="display:grid;grid-template-columns:1.5fr 1fr 1fr;gap:48px;margin-bottom:64px;" class="footer-cols">
    <div>
      <img
        src="/assets/logo-light.png"
        alt="Escape Autoescuelas"
        style="height:56px;margin-bottom:20px;display:block;"
      />
      <p style="font-size:14px;line-height:1.7;color:rgba(255,255,255,0.55);max-width:280px;margin:0;">
        Autoescuela en Elx desde 2011. Coche, moto y ciclomotor. El mejor porcentaje de aprobados de la zona.
      </p>
    </div>

    <div>
      <div style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.15em;color:rgba(255,255,255,0.4);margin-bottom:16px;">CONTACTO</div>
      <div style="display:flex;flex-direction:column;gap:10px;font-size:14px;line-height:1.5;">
        <a href={siteConfig.mapsSearchUrl} target="_blank" rel="noopener" style="color:rgba(255,255,255,0.75);text-decoration:none;">{siteConfig.address}<br/>{siteConfig.zipCity}</a>
        <a href={siteConfig.phoneTel} style="color:rgba(255,255,255,0.75);text-decoration:none;font-family:var(--font-mono);">{siteConfig.phone}</a>
        <a href={`mailto:${siteConfig.email}`} style="color:rgba(255,255,255,0.75);text-decoration:none;font-family:var(--font-mono);font-size:12px;">{siteConfig.email}</a>
      </div>
    </div>

    <div>
      <div style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.15em;color:rgba(255,255,255,0.4);margin-bottom:16px;">HORARIO</div>
      <div style="font-size:14px;line-height:1.7;color:rgba(255,255,255,0.75);margin-bottom:20px;">
        L–V · 10:00–14:00<br/>L–V · 16:00–20:30<br/>
        <span style="font-size:12px;color:rgba(255,255,255,0.45);">Fines de semana por WhatsApp</span>
      </div>
      <div style="display:flex;gap:12px;">
        <a href={siteConfig.whatsappUrl} target="_blank" rel="noopener" aria-label="WhatsApp"
          style="width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.12);display:flex;align-items:center;justify-content:center;color:#fff;text-decoration:none;transition:background 0.2s;"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.15-.174.2-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
          </svg>
        </a>
        <a href={siteConfig.instagram} target="_blank" rel="noopener" aria-label="Instagram"
          style="width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.12);display:flex;align-items:center;justify-content:center;color:#fff;text-decoration:none;transition:background 0.2s;"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Barra inferior -->
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;border-top:1px solid rgba(255,255,255,0.1);padding-top:24px;font-size:12px;color:rgba(255,255,255,0.4);">
    <span>© {siteConfig.year} Escape Autoescuelas SL · {siteConfig.location}</span>
    <span style="display:flex;gap:16px;">
      <a href="/aviso-legal" style="color:inherit;text-decoration:none;">Aviso legal</a>
      <a href="/politica-privacidad" style="color:inherit;text-decoration:none;">Privacidad</a>
      <a href="/politica-cookies" style="color:inherit;text-decoration:none;">Cookies</a>
    </span>
  </div>
</footer>

<style>
  @media (max-width: 900px) {
    .footer-cols {
      grid-template-columns: 1fr 1fr !important;
    }
  }
  @media (max-width: 600px) {
    .footer-cols {
      grid-template-columns: 1fr !important;
    }
    #site-footer {
      padding: 56px 24px 24px !important;
    }
  }
</style>

<script is:inline>
  (function () {
    var done = false;
    var footer = document.getElementById('site-footer');
    if (!footer) return;

    function reveal() {
      if (done) return;
      done = true;
      var words = footer.querySelectorAll('.footer-word');
      words.forEach(function (w) {
        w.style.transform = 'translateY(0)';
        w.style.opacity = '1';
      });
      var line = footer.querySelector('.footer-line');
      if (line) line.style.transform = 'scaleX(1)';
    }

    if ('IntersectionObserver' in window) {
      var obs = new IntersectionObserver(function (entries) {
        if (entries[0].isIntersecting) { reveal(); obs.disconnect(); }
      }, { threshold: 0.2 });
      obs.observe(footer);
    } else {
      reveal();
    }
  })();
</script>
