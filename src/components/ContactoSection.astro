---
import { siteConfig } from "../config/site";
const RADIUS = 14;
---

<section style="padding:80px 56px;background:var(--escape-paper-2);" id="contacto" data-c="contacto">
  <div
    class="escape-reveal"
    style={`background:#fff;overflow:hidden;display:grid;grid-template-columns:1.2fr 1fr;border:1px solid var(--escape-line);border-radius:${RADIUS}px;`}
    data-c="contactoCard"
  >
    <!-- Info izquierda -->
    <div style="padding:56px;" data-c="contactoLeft">
      <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.15em;color:var(--escape-red);margin-bottom:16px;">● HABLEMOS</div>
      <h2
        style="font-family:var(--font-display);font-size:88px;line-height:0.95;letter-spacing:-0.04em;margin-top:0;"
        data-c="contactoTitle"
      >
        Ven a vernos.<br/>
        <span class="escape-italic" style="color:var(--escape-red);">Sin compromiso.</span>
      </h2>

      <div
        style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:32px;padding-top:24px;border-top:1px solid var(--escape-line);font-size:15px;line-height:1.5;"
        data-c="contacto-info"
      >
        <div>
          <strong>{siteConfig.address}</strong><br/>
          <a href={siteConfig.mapsSearchUrl} target="_blank" rel="noopener" style="text-decoration:none;color:inherit;">{siteConfig.zipCity}</a>
        </div>
        <div>
          <strong>L–V · 10:00–14:00 / 16:00–20:30</strong><br/>
          Fines de semana atendemos por WhatsApp
        </div>
        <div>
          <a href={siteConfig.phoneTel} style="text-decoration:none;color:inherit;"><strong>{siteConfig.phone}</strong></a>
        </div>
        <div>
          <a
            href="https://instagram.com/escapeautoescuelas"
            target="_blank"
            rel="noopener"
            style="text-decoration:none;color:inherit;display:inline-flex;align-items:center;gap:8px;"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--escape-red);">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
            <strong>@escapeautoescuelas</strong>
          </a>
        </div>
      </div>

      <div style="display:flex;flex-wrap:wrap;gap:12px;margin-top:32px;">
        <a
          href={siteConfig.whatsappUrl}
          target="_blank"
          rel="noopener"
          class="escape-btn"
          style="background:#25D366;color:#fff;border:0;padding:16px 24px;border-radius:999px;font-weight:700;font-size:15px;text-decoration:none;display:inline-flex;align-items:center;gap:10px;"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.15-.174.2-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
          WhatsApp ahora
        </a>
        <a
          href={siteConfig.phoneTel}
          class="escape-btn"
          style="background:var(--escape-ink);color:#fff;border:0;padding:14px 22px;border-radius:999px;font-weight:700;font-size:14px;text-decoration:none;display:inline-block;"
          aria-label={`Llamar al ${siteConfig.phone}`}
        >Llamar {siteConfig.phone}</a>
      </div>
    </div>

    <!-- Mapa derecha -->
    <div
      class="escape-map-wrap"
      style="display:block;position:relative;min-height:480px;background:var(--escape-ink);"
      data-c="mapWrap"
    >
      <iframe
        title="Ubicación Escape Autoescuelas"
        src={siteConfig.mapsEmbedUrl}
        style="width:100%;height:100%;border:0;position:absolute;inset:0;"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
      <a
        href={siteConfig.mapsSearchUrl}
        target="_blank"
        rel="noopener noreferrer"
        style="position:absolute;left:24px;bottom:24px;background:rgba(10,10,10,0.92);padding:12px 16px;border-radius:12px;color:#fff;display:flex;align-items:center;gap:12px;text-decoration:none;"
        aria-label="Abrir ubicación en Google Maps"
      >
        <div>
          <div style="font-family:var(--font-mono);font-size:10px;color:rgba(255,255,255,0.7);">VER EN GOOGLE MAPS</div>
          <div style="font-family:var(--font-display);font-size:18px;margin-top:2px;color:#fff;">Cómo llegar →</div>
        </div>
      </a>
    </div>
  </div>
</section>
