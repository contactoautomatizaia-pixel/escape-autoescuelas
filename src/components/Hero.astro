---
const WHATSAPP_URL = "https://wa.me/34601302309?text=Hola%2C%20quiero%20info%20de%20Escape%20Autoescuelas";
const RADIUS = 14;
---

<section
  id="inicio"
  style="position:relative;padding:80px 56px 56px;background:var(--escape-red);color:#fff;display:grid;grid-template-columns:1.4fr 1fr;gap:48px;overflow:hidden;min-height:720px;"
  data-c="hero"
  aria-labelledby="hero-title"
>
  <!-- Fondo decorativo -->
  <div style="position:absolute;inset:0;overflow:hidden;pointer-events:none;" aria-hidden="true">
    <div class="escape-blob-anim" style="position:absolute;width:600px;height:600px;border-radius:50%;background:rgba(0,0,0,0.18);top:-200px;right:-100px;filter:blur(20px);"></div>
    <div class="escape-blob-anim-delay" style="position:absolute;width:400px;height:400px;border-radius:50%;background:rgba(255,255,255,0.12);bottom:-100px;left:200px;filter:blur(40px);"></div>
    <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.05) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.05) 1px,transparent 1px);background-size:48px 48px;"></div>
  </div>

  <!-- Contenido principal -->
  <div class="escape-hero-anim" style="position:relative;z-index:2;display:flex;flex-direction:column;justify-content:center;">
    <div style="display:flex;align-items:center;gap:10px;font-family:var(--font-mono);font-size:12px;letter-spacing:0.15em;color:rgba(255,255,255,0.85);">
      <span class="escape-dot-pulse" style="width:8px;height:8px;border-radius:50%;background:#fff;display:inline-block;" aria-hidden="true"></span>
      AUTOESCUELA · ELX · ALICANTE
    </div>

    <h1
      id="hero-title"
      data-c="hero-title"
      style="display:flex;flex-direction:column;margin-top:24px;font-family:var(--font-display);font-size:88px;line-height:0.92;letter-spacing:-0.045em;"
    >
      <span style="display:block;">Saca el carnet</span>
      <span style="display:block;color:rgba(255,255,255,0.55);" data-c="hero-tl2">en Elche con un</span>
      <span
        style="display:block;color:#fff;font-size:110px;"
        data-c="hero-tl3"
        class="escape-italic"
      >63% aprobados.</span>
    </h1>

    <p
      style="font-size:20px;line-height:1.5;color:rgba(255,255,255,0.92);margin-top:32px;max-width:560px;"
      data-c="hero-lead"
    >
      (la media en Elche es 43%) — desde 2011, plataforma online 24/7 y profes que te conocen por tu nombre.
    </p>

    <div style="display:flex;flex-wrap:wrap;gap:12px;margin-top:32px;" data-c="hero-ctas">
      <a
        href="/contacto"
        class="escape-btn escape-btn-pulse"
        style="background:#fff;color:var(--escape-red);border:0;padding:16px 24px;border-radius:999px;font-weight:700;font-size:15px;text-decoration:none;display:inline-block;"
      >Empezar mi matrícula</a>
      <a
        href={WHATSAPP_URL}
        target="_blank"
        rel="noopener"
        class="escape-btn hero-wa-btn"
        style="background:#25D366;color:#fff;border:0;padding:14px 24px;border-radius:999px;font-weight:700;font-size:15px;text-decoration:none;display:inline-flex;align-items:center;gap:10px;"
        aria-label="Escríbenos por WhatsApp"
      >
        <span class="hero-wa-icon" style="display:flex;align-items:center;justify-content:center;width:28px;height:28px;background:rgba(255,255,255,0.2);border-radius:50%;flex-shrink:0;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.15-.174.2-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
          </svg>
        </span>
        Hablar por WhatsApp
      </a>

      <style>
        @keyframes wa-hero-pulse {
          0%, 100% { box-shadow: 0 0 0 0 rgba(37,211,102,0.6), 0 6px 20px rgba(37,211,102,0.35); }
          50%       { box-shadow: 0 0 0 10px rgba(37,211,102,0), 0 6px 20px rgba(37,211,102,0.35); }
        }
        .hero-wa-btn {
          animation: wa-hero-pulse 2.2s ease-in-out infinite;
        }
        .hero-wa-btn:hover {
          background: #1db954 !important;
          transform: translateY(-2px);
          box-shadow: 0 12px 28px rgba(37,211,102,0.45) !important;
        }
        .hero-wa-btn:hover .hero-wa-icon {
          background: rgba(255,255,255,0.3);
        }
      </style>
    </div>

    <div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:32px;">
      <span class="escape-chip" style="background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.2);padding:8px 14px;border-radius:999px;font-size:13px;font-weight:500;">✓ Coche B · 230€</span>
      <span class="escape-chip" style="background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.2);padding:8px 14px;border-radius:999px;font-size:13px;font-weight:500;">✓ Moto A1/A2 · 180€</span>
      <span class="escape-chip" style="background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.2);padding:8px 14px;border-radius:999px;font-size:13px;font-weight:500;">✓ Ciclomotor AM · 220€</span>
      <span class="escape-chip" style="background:#fff;color:var(--escape-red);padding:8px 14px;border-radius:999px;font-size:13px;font-weight:700;">★ Promo amigo 2+2</span>
    </div>
  </div>

  <!-- Panel derecho -->
  <div class="escape-hero-anim" style="position:relative;z-index:2;display:flex;flex-direction:column;gap:24px;">
    <div
      data-c="hero-bignum"
      id="hero-bignum"
      style={`background:var(--escape-ink);color:#fff;padding:32px;display:flex;align-items:center;gap:24px;border-radius:${RADIUS - 4}px;position:relative;overflow:hidden;`}
    >
      <!-- Barra de progreso animada en el fondo -->
      <div id="hero-progress-bar" style="position:absolute;bottom:0;left:0;height:3px;background:linear-gradient(90deg,var(--escape-red),#FFB800);width:0%;transition:width 1.8s cubic-bezier(0.22,1,0.36,1);border-radius:0 2px 0 0;"></div>

      <div style="display:flex;flex-direction:column;align-items:flex-start;">
        <span
          data-c="hero-bignum-val"
          id="hero-counter"
          style="font-family:var(--font-display);font-size:120px;line-height:0.85;letter-spacing:-0.04em;tabular-nums:true;"
        >0<span style="font-size:0.5em;">%</span></span>
        <div style="margin-top:8px;height:2px;width:0%;background:var(--escape-red);border-radius:2px;transition:width 1.8s cubic-bezier(0.22,1,0.36,1);" id="hero-underline"></div>
      </div>

      <div style="display:flex;flex-direction:column;gap:6px;">
        <span style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.7);line-height:1.4;">
          aprobados<br/>al práctico
        </span>
        <span style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.08em;color:var(--escape-red);font-weight:700;">vs 43% Elche</span>
        <!-- Mini barra comparativa -->
        <div style="display:flex;flex-direction:column;gap:4px;margin-top:4px;">
          <div style="display:flex;align-items:center;gap:6px;">
            <div style="height:5px;border-radius:999px;background:#fff;width:0%;transition:width 2s cubic-bezier(0.22,1,0.36,1);max-width:80px;" id="bar-escape"></div>
            <span style="font-size:10px;color:rgba(255,255,255,0.6);font-family:var(--font-mono);">Escape</span>
          </div>
          <div style="display:flex;align-items:center;gap:6px;">
            <div style="height:5px;border-radius:999px;background:rgba(255,255,255,0.3);width:0%;transition:width 2s cubic-bezier(0.22,1,0.36,1);max-width:80px;" id="bar-media"></div>
            <span style="font-size:10px;color:rgba(255,255,255,0.4);font-family:var(--font-mono);">Media</span>
          </div>
        </div>
      </div>
    </div>

    <script is:inline>
      (function() {
        var started = false;
        var target = 63;
        var duration = 1800;

        function easeOut(t) { return 1 - Math.pow(1 - t, 3); }

        function startCounter() {
          if (started) return;
          started = true;

          var el = document.getElementById('hero-counter');
          var bar = document.getElementById('hero-progress-bar');
          var underline = document.getElementById('hero-underline');
          var barEscape = document.getElementById('bar-escape');
          var barMedia = document.getElementById('bar-media');
          if (!el) return;

          var start = null;
          function step(ts) {
            if (!start) start = ts;
            var progress = Math.min((ts - start) / duration, 1);
            var eased = easeOut(progress);
            var current = Math.round(eased * target);
            el.childNodes[0].nodeValue = current;
            if (bar) bar.style.width = (eased * 100) + '%';
            if (underline) underline.style.width = (eased * 60) + 'px';
            if (progress < 1) {
              requestAnimationFrame(step);
            } else {
              el.childNodes[0].nodeValue = target;
              if (barEscape) barEscape.style.width = '73px';
              if (barMedia)  barMedia.style.width  = '44px';
            }
          }
          // Iniciar barras con delay
          setTimeout(function() {
            if (barEscape) barEscape.style.width = '73px';
            if (barMedia)  barMedia.style.width  = '44px';
          }, 300);
          requestAnimationFrame(step);
        }

        var bignum = document.getElementById('hero-bignum');
        if (!bignum) return;

        if ('IntersectionObserver' in window) {
          var obs = new IntersectionObserver(function(entries) {
            if (entries[0].isIntersecting) { startCounter(); obs.disconnect(); }
          }, { threshold: 0.3 });
          obs.observe(bignum);
        } else {
          startCounter();
        }
      })();
    </script>

    <div
      class="escape-photo-wrap"
      style={`position:relative;overflow:hidden;flex:1;min-height:320px;border-radius:${RADIUS - 4}px;`}
    >
      <img
        src="/assets/local.webp"
        alt="Local de Escape Autoescuelas en Elx"
        style="width:100%;height:100%;object-fit:cover;"
        loading="eager"
        width="800"
        height="600"
      />
      <div style="position:absolute;left:16px;bottom:16px;background:rgba(10,10,10,0.85);color:#fff;padding:10px 14px;border-radius:12px;display:flex;flex-direction:column;gap:2px;">
        <span style="font-family:var(--font-mono);font-size:10px;">ELX · 03202</span>
        <span style="font-family:var(--font-display);font-size:16px;">Jaime Gómez Orts, 18</span>
      </div>
    </div>
  </div>
</section>
