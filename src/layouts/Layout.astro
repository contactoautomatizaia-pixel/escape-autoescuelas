---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  schemas?: string[];
  preloadHero?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage = "https://escapeautoescuelas.com/assets/og-image.png",
  schemas = [],
  preloadHero = false,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#C8102E" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Escape Autoescuelas" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="geo.region" content="ES-VC" />
    <meta name="geo.placename" content="Elx, Alicante" />
    <meta name="geo.position" content="38.265;-0.701" />
    <meta name="ICBM" content="38.265, -0.701" />
    <link rel="canonical" href={canonical} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Escape Autoescuelas" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Preload imagen hero (solo home) -->
    {preloadHero && <link rel="preload" as="image" href="/assets/local.webp" fetchpriority="high" />}

    <!-- Google Fonts — carga no bloqueante -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Bebas+Neue&family=Fraunces:ital,opsz,wght@0,9..144,400;1,9..144,400&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Bebas+Neue&family=Fraunces:ital,opsz,wght@0,9..144,400;1,9..144,400&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    </noscript>

    <!-- Schema.org JSON-LD -->
    {schemas.map((schema) => <script type="application/ld+json" set:html={schema} />)}

    <style>
      html, body { margin: 0; padding: 0; background: #F5F2EC; }
      body { font-family: "Inter", system-ui, sans-serif; padding-top: 79px; }

      /* ── Back to top ── */
      #back-to-top {
        position: fixed; bottom: 96px; right: 24px; z-index: 90;
        width: 44px; height: 44px; border-radius: 50%;
        background: var(--escape-ink, #0A0A0A); color: #fff; border: none;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 4px 16px rgba(0,0,0,0.25);
        cursor: pointer;
        opacity: 0; pointer-events: none;
        transform: translateY(12px);
        transition: opacity 0.35s cubic-bezier(0.22,1,0.36,1),
                    transform 0.35s cubic-bezier(0.22,1,0.36,1),
                    background 0.2s, box-shadow 0.2s;
      }
      #back-to-top.is-visible { opacity: 1; pointer-events: auto; transform: translateY(0); }
      #back-to-top:hover { background: var(--escape-red, #C8102E); box-shadow: 0 6px 20px rgba(200,16,46,0.4); }
      @media (max-width: 768px) { #back-to-top { display: none !important; } }
    </style>
  </head>
  <body>
    <!-- WhatsApp flotante (solo mobile) -->
    <a
      class="wa-float"
      href="https://wa.me/34601302309?text=Hola%2C%20quiero%20info%20de%20Escape%20Autoescuelas"
      target="_blank"
      rel="noopener"
      aria-label="Contactar por WhatsApp"
    >
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.15-.174.2-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
      </svg>
    </a>

    <slot />

    <!-- Back to top button -->
    <button id="back-to-top" aria-label="Volver arriba" title="Volver arriba">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="18 15 12 9 6 15"/>
      </svg>
    </button>

    <!-- Cookie banner RGPD -->
    <script src="/cookies-banner.js" is:inline></script>

    <!-- Reveal on scroll -->
    <script is:inline>
      (function () {
        if (typeof IntersectionObserver === "undefined") {
          document.querySelectorAll(".escape-reveal, .escape-reveal-stagger, .fade-in, .reveal")
            .forEach((el) => el.classList.add("is-visible"));
          return;
        }
        const obs = new IntersectionObserver(
          (entries) => entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("is-visible");
              obs.unobserve(e.target);
            }
          }),
          { threshold: 0.12, rootMargin: "0px 0px -60px 0px" }
        );
        const watchAll = () =>
          document.querySelectorAll(
            ".escape-reveal:not(.is-visible), .escape-reveal-stagger:not(.is-visible), .fade-in:not(.is-visible), .reveal:not(.is-visible)"
          ).forEach((el) => obs.observe(el));
        watchAll();
        new MutationObserver(watchAll).observe(document.body, { childList: true, subtree: true });
      })();
    </script>

    <!-- Back to top logic -->
    <script is:inline>
      (function () {
        var btn = document.getElementById('back-to-top');
        if (!btn) return;
        window.addEventListener('scroll', function () {
          btn.classList.toggle('is-visible', window.scrollY > 400);
        }, { passive: true });
        btn.addEventListener('click', function () {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      })();
    </script>

    <!-- Mouse-tracking spotlight para cards -->
    <script is:inline>
      (() => {
        let pending = null;
        document.addEventListener("pointermove", (e) => {
          if (pending) return;
          pending = e;
          requestAnimationFrame(() => {
            const ev = pending; pending = null;
            const el = ev.target && ev.target.closest && ev.target.closest(".escape-card, .escape-perm-card");
            if (!el) return;
            const r = el.getBoundingClientRect();
            el.style.setProperty("--mx", (ev.clientX - r.left) + "px");
            el.style.setProperty("--my", (ev.clientY - r.top) + "px");
          });
        }, { passive: true });
      })();
    </script>
  </body>
</html>
