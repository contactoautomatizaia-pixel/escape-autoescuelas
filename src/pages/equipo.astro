---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const WHATSAPP_URL = "https://wa.me/34601302309?text=Hola%2C%20quiero%20info%20de%20Escape%20Autoescuelas";
const PHONE_TEL = "tel:+34601302309";

const stats = [
  { val: "2011", label: "Fundada en Elx",       num: 2011, start: 1990, prefix: "",  suffix: ""  },
  { val: "+500", label: "Alumnos formados",      num: 500,  start: 0,    prefix: "+", suffix: ""  },
  { val: "15+",  label: "Años de experiencia",  num: 15,   start: 0,    prefix: "",  suffix: "+" },
  { val: "2",    label: "Generaciones",          num: 2,    start: 0,    prefix: "",  suffix: ""  },
];
---

<Layout
  title="Nuestro Equipo · Juan de Dios y Aitor Sánchez · Escape Autoescuelas Elche"
  description="Conoce a Juan de Dios y Aitor Sánchez, padre e hijo, equipo de Escape Autoescuelas en Elche desde 2011. Más de 500 alumnos formados, mismo local, mismo compromiso."
  canonical="https://escapeautoescuelas.com/equipo"
>
  <div class="escape-root" style="background:var(--escape-paper);color:var(--escape-ink);width:100%;overflow:hidden;">
    <Nav activePage="equipo" />

    <!-- HERO -->
    <section style="padding:120px 56px 80px;background:var(--escape-ink);color:#fff;position:relative;overflow:hidden;min-height:560px;display:flex;align-items:center;" data-c="equipoHero">
      <div aria-hidden="true" style="position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.03) 1px,transparent 1px);background-size:48px 48px;pointer-events:none;"></div>
      <div class="escape-blob-anim" aria-hidden="true" style="position:absolute;width:700px;height:700px;border-radius:50%;background:rgba(200,16,46,0.08);top:-200px;right:-150px;filter:blur(60px);pointer-events:none;"></div>
      <div class="escape-blob-anim-delay" aria-hidden="true" style="position:absolute;width:400px;height:400px;border-radius:50%;background:rgba(200,16,46,0.06);bottom:-100px;left:-80px;filter:blur(40px);pointer-events:none;"></div>

      <div style="position:relative;width:100%;max-width:1100px;">
        <div style="display:flex;align-items:center;gap:10px;font-family:var(--font-mono);font-size:11px;letter-spacing:0.2em;color:rgba(255,255,255,0.4);margin-bottom:32px;">
          <span style="width:24px;height:1px;background:var(--escape-red);display:inline-block;"></span>
          EL EQUIPO · DESDE 2011
        </div>
        <h1 style="font-family:var(--font-display);font-size:clamp(52px,8vw,120px);line-height:0.9;letter-spacing:-0.045em;margin:0 0 32px;">
          Una familia.<br/>
          Un local.<br/>
          <span class="escape-italic" style="color:var(--escape-red);">Miles de carnets.</span>
        </h1>
        <p style="font-size:18px;line-height:1.65;color:rgba(255,255,255,0.65);max-width:600px;margin:0;">
          Padre e hijo. Mismo local desde el primer día. La misma vocación que en 2011, con más de 500 alumnos formados y dos generaciones de experiencia sobre el asfalto de Elx.
        </p>
      </div>
    </section>

    <!-- STATS STRIP -->
    <div style="background:var(--escape-red);color:#fff;padding:0 56px;" class="eq-stats-wrap" id="eq-stats-strip">
      <div style="display:grid;grid-template-columns:repeat(4,1fr);" class="eq-stats-grid">
        {stats.map((s, i) => (
          <div
            style={`padding:32px 0;border-right:1px solid rgba(255,255,255,0.15);display:flex;flex-direction:column;gap:6px;transition-delay:${i*90}ms;`}
            class="eq-stat-item eq-stat-reveal"
          >
            <span
              class="eq-stat-num"
              data-target={s.num}
              data-start={s.start}
              data-prefix={s.prefix}
              data-suffix={s.suffix}
              style="font-family:var(--font-display);font-size:clamp(40px,5vw,72px);line-height:1;letter-spacing:-0.04em;"
            >{s.val}</span>
            <span style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.18em;color:rgba(255,255,255,0.65);">{s.label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- JUAN DE DIOS -->
    <section style="padding:80px 56px;background:var(--escape-paper);" data-c="juanSection">
      <div class="escape-reveal" style="display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;" data-c="juanGrid">
        <!-- Foto -->
        <div style="position:relative;">
          <div style="aspect-ratio:3/4;overflow:hidden;border-radius:20px;background:var(--escape-paper-2);">
            <img
              src="/assets/juan.webp"
              alt="Juan de Dios Sánchez, fundador y profesor de Escape Autoescuelas Elche"
              style="width:100%;height:100%;object-fit:cover;object-position:center top;"
              loading="lazy"
            />
          </div>
          <!-- Badge fundador -->
          <div style="position:absolute;bottom:24px;left:24px;background:var(--escape-ink);color:#fff;padding:14px 20px;border-radius:14px;backdrop-filter:blur(10px);">
            <div style="font-family:var(--font-mono);font-size:9px;letter-spacing:0.18em;color:rgba(255,255,255,0.5);margin-bottom:4px;">FUNDADOR</div>
            <div style="font-family:var(--font-display);font-size:18px;letter-spacing:-0.02em;">Desde 2011</div>
          </div>
        </div>

        <!-- Bio -->
        <div>
          <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.2em;color:var(--escape-red);margin-bottom:20px;display:flex;align-items:center;gap:10px;">
            <span style="width:20px;height:1px;background:var(--escape-red);display:inline-block;"></span>
            EL PADRE
          </div>
          <h2 style="font-family:var(--font-display);font-size:clamp(48px,6vw,80px);line-height:0.9;letter-spacing:-0.04em;margin:0 0 28px;">
            Juan de Dios<br/>Sánchez.
          </h2>
          <p style="font-size:17px;line-height:1.7;color:var(--escape-ink-2);margin-bottom:20px;">
            En 2011, Juan de Dios abrió Escape Autoescuelas en el mismo local donde sigue hoy. No buscó la fórmula rápida: construyó una reputación alumno a alumno, clase a clase, con paciencia y exigencia a partes iguales.
          </p>
          <p style="font-size:17px;line-height:1.7;color:var(--escape-ink-2);margin-bottom:32px;">
            Más de 500 alumnos después, su método sigue siendo el mismo: conocer a cada persona, entender cómo aprende y no darle el visto bueno hasta que de verdad está listo para el examen.
          </p>
          <div style="display:flex;flex-wrap:wrap;gap:8px;">
            <span style="background:var(--escape-paper-2);border:1px solid var(--escape-line);padding:8px 16px;border-radius:999px;font-size:13px;font-weight:500;">Permiso B · Coche</span>
            <span style="background:var(--escape-paper-2);border:1px solid var(--escape-line);padding:8px 16px;border-radius:999px;font-size:13px;font-weight:500;">Permiso A · Moto</span>
            <span style="background:var(--escape-red);color:#fff;padding:8px 16px;border-radius:999px;font-size:13px;font-weight:700;">+15 años formando conductores</span>
          </div>
        </div>
      </div>
    </section>

    <!-- DIVISOR -->
    <div style="padding:0 56px;" class="eq-divider-wrap">
      <div style="height:1px;background:var(--escape-line);"></div>
    </div>

    <!-- AITOR -->
    <section style="padding:80px 56px;background:var(--escape-paper);" data-c="aitorSection">
      <div class="escape-reveal" style="display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;" data-c="aitorGrid">
        <!-- Bio (izquierda en este caso) -->
        <div>
          <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.2em;color:var(--escape-red);margin-bottom:20px;display:flex;align-items:center;gap:10px;">
            <span style="width:20px;height:1px;background:var(--escape-red);display:inline-block;"></span>
            EL HIJO
          </div>
          <h2 style="font-family:var(--font-display);font-size:clamp(48px,6vw,80px);line-height:0.9;letter-spacing:-0.04em;margin:0 0 28px;">
            Aitor<br/>Sánchez.
          </h2>
          <p style="font-size:17px;line-height:1.7;color:var(--escape-ink-2);margin-bottom:20px;">
            Aitor creció entre exámenes de tráfico y clases prácticas. Lo que para otros es un trabajo, para él es la continuación de algo que lleva viendo desde niño. Cuando se incorporó a Escape, no tuvo que aprender la filosofía del sitio: la llevaba de serie.
          </p>
          <p style="font-size:17px;line-height:1.7;color:var(--escape-ink-2);margin-bottom:32px;">
            Aporta frescura sin perder rigor. Conecta rápido con los alumnos más jóvenes y mantiene la misma exigencia que le inculcó su padre: nadie sale a examen antes de estar preparado.
          </p>
          <div style="display:flex;flex-wrap:wrap;gap:8px;">
            <span style="background:var(--escape-paper-2);border:1px solid var(--escape-line);padding:8px 16px;border-radius:999px;font-size:13px;font-weight:500;">Permiso B · Coche</span>
            <span style="background:var(--escape-paper-2);border:1px solid var(--escape-line);padding:8px 16px;border-radius:999px;font-size:13px;font-weight:500;">Permiso A · Moto</span>
            <span style="background:var(--escape-ink);color:#fff;padding:8px 16px;border-radius:999px;font-size:13px;font-weight:700;">Segunda generación</span>
          </div>
        </div>

        <!-- Foto -->
        <div style="position:relative;">
          <div style="aspect-ratio:3/4;overflow:hidden;border-radius:20px;background:var(--escape-paper-2);">
            <img
              src="/assets/aitor.webp"
              alt="Aitor Sánchez, profesor de Escape Autoescuelas Elche e hijo del fundador"
              style="width:100%;height:100%;object-fit:cover;object-position:center top;"
              loading="lazy"
            />
          </div>
          <!-- Badge -->
          <div style="position:absolute;bottom:24px;right:24px;background:var(--escape-red);color:#fff;padding:14px 20px;border-radius:14px;">
            <div style="font-family:var(--font-mono);font-size:9px;letter-spacing:0.18em;color:rgba(255,255,255,0.7);margin-bottom:4px;">2.ª GENERACIÓN</div>
            <div style="font-family:var(--font-display);font-size:18px;letter-spacing:-0.02em;">El futuro</div>
          </div>
        </div>
      </div>
    </section>

    <!-- HISTORIA: bloque oscuro -->
    <section class="escape-reveal" style="padding:80px 56px;background:var(--escape-ink);color:#fff;" data-c="historiaSection">
      <div style="max-width:900px;margin:0 auto;text-align:center;">
        <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.2em;color:var(--escape-red);margin-bottom:24px;">&#9679; NUESTRA HISTORIA</div>
        <h2 style="font-family:var(--font-display);font-size:clamp(40px,6vw,88px);line-height:0.92;letter-spacing:-0.045em;margin:0 0 40px;">
          El mismo local.<br/>La misma <span class="escape-italic" style="color:var(--escape-red);">promesa.</span>
        </h2>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:40px;text-align:left;margin-bottom:48px;" class="historia-cols">
          <div>
            <div style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.15em;color:rgba(255,255,255,0.35);margin-bottom:12px;">2011</div>
            <p style="font-size:16px;line-height:1.7;color:rgba(255,255,255,0.7);">Juan de Dios abre Escape Autoescuelas en el Carrer Jaime Gómez Orts, 18. Un local, una visión: formar conductores de verdad, sin atajos.</p>
          </div>
          <div>
            <div style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.15em;color:rgba(255,255,255,0.35);margin-bottom:12px;">HOY</div>
            <p style="font-size:16px;line-height:1.7;color:rgba(255,255,255,0.7);">Padre e hijo, mismo local, más de 500 alumnos formados. El 63% aprueba el práctico a la primera, frente al 43% de media en Elche. Los números hablan solos.</p>
          </div>
        </div>
        <div style="width:64px;height:1px;background:var(--escape-red);margin:0 auto 40px;"></div>
        <p style="font-size:20px;line-height:1.6;color:rgba(255,255,255,0.8);font-style:italic;max-width:700px;margin:0 auto;">
          &ldquo;Llevamos más de 15 años en el mismo sitio porque hacemos bien nuestro trabajo. Nuestros alumnos vuelven a mandarnos a sus amigos, a sus hermanos, a sus hijos. Esa es nuestra mejor publicidad.&rdquo;
        </p>
        <div style="margin-top:16px;font-family:var(--font-mono);font-size:11px;color:rgba(255,255,255,0.35);letter-spacing:0.1em;">— Juan de Dios Sánchez, fundador</div>
      </div>
    </section>

    <!-- CTA FINAL -->
    <section class="escape-reveal" style="padding:80px 56px;" data-c="equipoCta">
      <div style="background:var(--escape-red);color:#fff;border-radius:24px;padding:64px 56px;display:grid;grid-template-columns:1fr auto;gap:48px;align-items:center;" class="equipo-cta-inner">
        <div>
          <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.18em;color:rgba(255,255,255,0.6);margin-bottom:14px;">EMPEZAMOS CUANDO QUIERAS</div>
          <h2 style="font-family:var(--font-display);font-size:clamp(36px,4.5vw,64px);line-height:0.92;letter-spacing:-0.04em;margin:0 0 16px;">
            Ven a conocer<br/>al equipo.
          </h2>
          <p style="font-size:16px;color:rgba(255,255,255,0.75);margin:0;line-height:1.6;">Sin compromiso. Cuéntanos lo que necesitas y te orientamos sin rodeos.</p>
        </div>
        <div style="display:flex;flex-direction:column;gap:12px;flex-shrink:0;">
          <a href={WHATSAPP_URL} target="_blank" rel="noopener"
            style="background:#25D366;color:#fff;padding:16px 28px;border-radius:999px;font-weight:700;font-size:15px;text-decoration:none;display:inline-flex;align-items:center;gap:10px;white-space:nowrap;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.15-.174.2-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
            WhatsApp ahora
          </a>
          <a href={PHONE_TEL}
            style="background:rgba(255,255,255,0.15);color:#fff;border:1px solid rgba(255,255,255,0.3);padding:16px 28px;border-radius:999px;font-weight:600;font-size:15px;text-decoration:none;text-align:center;white-space:nowrap;">
            Llamar
          </a>
        </div>
      </div>
    </section>

    <style>
      /* Stats strip */
      .eq-stats-wrap { padding: 0 56px; }
      .eq-stat-item:last-child { border-right: none; }
      .eq-stat-item { padding-left: 32px; }
      .eq-stat-item:first-child { padding-left: 0; }

      /* Responsive */
      @media (max-width: 900px) {
        [data-c="equipoHero"]   { padding: 96px 24px 56px !important; min-height: unset !important; }
        [data-c="juanSection"],
        [data-c="aitorSection"] { padding: 56px 24px !important; }
        [data-c="juanGrid"],
        [data-c="aitorGrid"]    { grid-template-columns: 1fr !important; gap: 36px !important; }
        /* En movil la foto va primero en las dos secciones */
        [data-c="aitorGrid"] > div:first-child { order: 2; }
        [data-c="aitorGrid"] > div:last-child  { order: 1; }
        [data-c="historiaSection"] { padding: 56px 24px !important; }
        .historia-cols { grid-template-columns: 1fr !important; gap: 24px !important; }
        .eq-stats-wrap { padding: 0 24px; }
        .eq-stats-grid { grid-template-columns: 1fr 1fr !important; }
        .eq-stat-item { border-right: none !important; border-bottom: 1px solid rgba(255,255,255,0.1); padding: 24px 0 24px 0 !important; }
        .eq-divider-wrap { padding: 0 24px !important; }
        [data-c="equipoCta"] { padding: 48px 24px !important; }
        .equipo-cta-inner { grid-template-columns: 1fr !important; padding: 36px 28px !important; gap: 28px !important; }
      }
      @media (max-width: 540px) {
        .eq-stats-grid { grid-template-columns: 1fr 1fr !important; }
      }

      /* Stat reveal animation */
      .eq-stat-reveal {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.6s ease, transform 0.6s cubic-bezier(0.22,1,0.36,1);
      }
      .eq-stat-reveal.is-visible {
        opacity: 1;
        transform: translateY(0);
      }
    </style>

    <script>
      (function() {
        var strip = document.getElementById('eq-stats-strip');
        if (!strip) return;

        var items = strip.querySelectorAll('.eq-stat-reveal');
        var nums  = strip.querySelectorAll('.eq-stat-num');
        var triggered = false;

        function easeOut(t) { return 1 - Math.pow(1 - t, 3); }

        function countUp(el, from, to, prefix, suffix, delay) {
          var duration = 1600;
          var start = null;
          setTimeout(function() {
            requestAnimationFrame(function step(ts) {
              if (!start) start = ts;
              var p = Math.min((ts - start) / duration, 1);
              el.textContent = prefix + Math.round(from + easeOut(p) * (to - from)) + suffix;
              if (p < 1) requestAnimationFrame(step);
            });
          }, delay);
        }

        function run() {
          if (triggered) return;
          triggered = true;
          // Reveal items
          items.forEach(function(item) { item.classList.add('is-visible'); });
          // Count-up numbers
          nums.forEach(function(el, i) {
            var target = parseInt(el.dataset.target, 10);
            var startVal = parseInt(el.dataset.start, 10);
            var prefix = el.dataset.prefix || '';
            var suffix = el.dataset.suffix || '';
            el.textContent = prefix + startVal + suffix;
            countUp(el, startVal, target, prefix, suffix, i * 90);
          });
        }

        var observer = new IntersectionObserver(function(entries) {
          if (entries[0].isIntersecting) {
            run();
            observer.disconnect();
          }
        }, { threshold: 0.3 });

        observer.observe(strip);
      })();
    </script>

    <Footer />
  </div>
</Layout>
