---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { siteConfig } from "../config/site";

const pilares = [
  {
    n: "01",
    t: "Plataforma online 24/7",
    d: "Vídeos por temas, manual digital y tests ilimitados. Estudia desde el bus, en pausas del curro o en el sofá. Sin horarios, sin excusas.",
    tag: "ACCESO TOTAL",
  },
  {
    n: "02",
    t: "Tests cronometrados estilo DGT",
    d: "Mismas preguntas, mismo formato, mismo tiempo. Cuando llegas al examen real no hay sorpresas: ya lo has hecho cientos de veces.",
    tag: "SIMULACION REAL",
  },
  {
    n: "03",
    t: "Seguimiento personal",
    d: "Tu profe ve tu progreso en tiempo real y te avisa cuando de verdad estás listo. No vas a ciegas ni te mandamos antes de tiempo.",
    tag: "SIN SORPRESAS",
  },
  {
    n: "04",
    t: "Tests presenciales en la academia",
    d: "Ven a la autoescuela y haz tests con nosotros las veces que necesites. El entorno cambia, la concentración se entrena.",
    tag: "PRESENCIAL",
  },
];

const pasos = [
  { n: "01", t: "Matrícula", d: "Te das de alta, te explicamos todo y empezamos." },
  { n: "02", t: "Plataforma", d: "Accedes online desde el primer día, a tu ritmo." },
  { n: "03", t: "Tests", d: "Presenciales y cronometrados hasta estar listo." },
  { n: "04", t: "Examen DGT", d: "Vas con garantías. El 98% aprueba." },
];

const schemaFaq = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cuánto tarda en aprobarse el teórico del carnet en Elche?",
      "acceptedAnswer": { "@type": "Answer", "text": "Con el método de Escape Autoescuelas, la mayoría de alumnos aprueba el teórico entre 3 y 6 semanas. El 98% supera el examen teórico, gracias a la plataforma online 24/7 y el seguimiento personal del profesor." }
    },
    {
      "@type": "Question",
      "name": "¿Cómo se estudia el teórico del carnet de conducir en Escape Autoescuelas?",
      "acceptedAnswer": { "@type": "Answer", "text": "Con acceso a una plataforma online con vídeos, manual digital y tests ilimitados. También se realizan tests presenciales en la academia y tests cronometrados idénticos al examen DGT real." }
    },
    {
      "@type": "Question",
      "name": "¿Cuál es el porcentaje de aprobados al teórico en Escape Autoescuelas Elche?",
      "acceptedAnswer": { "@type": "Answer", "text": "El 98% de los alumnos de Escape Autoescuelas supera el examen teórico de la DGT. La media nacional ronda el 73%." }
    }
  ]
});
---

<Layout
  title="Teoría y Método · 98% Aprobados al Teórico · Escape Autoescuelas Elche"
  description="El método con el que el 98% de nuestros alumnos aprueba el teórico del carnet en Elche. Plataforma online 24/7, tests estilo DGT, seguimiento personal y tests presenciales."
  canonical="https://escapeautoescuelas.com/teoria-metodo"
  schemas={[schemaFaq]}
>
  <div class="escape-root" style="background:var(--escape-paper);color:var(--escape-ink);width:100%;overflow:hidden;">
    <Nav activePage="teoria" />

    <!-- ═══ HERO ═══ -->
    <section style="background:var(--escape-ink);color:#fff;padding:120px 56px 80px;position:relative;overflow:hidden;min-height:600px;display:flex;align-items:center;" data-c="teoriaHero">
      <div aria-hidden="true" style="position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.03) 1px,transparent 1px);background-size:48px 48px;pointer-events:none;"></div>
      <div class="escape-blob-anim" aria-hidden="true" style="position:absolute;width:800px;height:800px;border-radius:50%;background:rgba(200,16,46,0.07);top:-300px;right:-200px;filter:blur(60px);pointer-events:none;"></div>
      <div class="escape-blob-anim-delay" aria-hidden="true" style="position:absolute;width:500px;height:500px;border-radius:50%;background:rgba(200,16,46,0.05);bottom:-150px;left:-100px;filter:blur(50px);pointer-events:none;"></div>

      <div style="position:relative;width:100%;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;" class="teoria-hero-grid">
        <!-- Izquierda -->
        <div class="th-left">
          <div style="display:flex;align-items:center;gap:10px;font-family:var(--font-mono);font-size:11px;letter-spacing:0.2em;color:rgba(255,255,255,0.4);margin-bottom:28px;">
            <span style="width:24px;height:1px;background:var(--escape-red);display:inline-block;"></span>
            TEORÍA Y MÉTODO
          </div>
          <h1 style="font-family:var(--font-display);font-size:clamp(48px,7vw,108px);line-height:0.9;letter-spacing:-0.045em;margin:0 0 28px;">
            <span id="teoria-counter" style="color:var(--escape-red);">0</span><span style="color:var(--escape-red);font-size:0.55em;">%</span><br/>
            al teórico.<br/>
            <span class="escape-italic" style="color:rgba(255,255,255,0.9);font-size:0.75em;">Así lo conseguimos.</span>
          </h1>
          <p style="font-size:17px;line-height:1.65;color:rgba(255,255,255,0.6);max-width:520px;margin:0 0 36px;">
            No es casualidad. Es un método construido durante 15 años en Elx, con plataforma propia, seguimiento real y tests al estilo DGT desde el primer día.
          </p>
          <div style="display:flex;gap:12px;flex-wrap:wrap;">
            <a href={siteConfig.whatsappUrl} target="_blank" rel="noopener" style="background:#25D366;color:#fff;padding:14px 24px;border-radius:999px;font-weight:700;font-size:14px;text-decoration:none;display:inline-flex;align-items:center;gap:8px;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.15-.174.2-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
              Matricularme
            </a>
            <a href="#pilares" style="background:rgba(255,255,255,0.08);color:#fff;border:1px solid rgba(255,255,255,0.15);padding:14px 24px;border-radius:999px;font-weight:600;font-size:14px;text-decoration:none;">Ver el método</a>
          </div>
        </div>

        <!-- Derecha: comparativa -->
        <div class="th-right" style="display:flex;flex-direction:column;gap:20px;">
          <div style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.18em;color:rgba(255,255,255,0.35);margin-bottom:4px;">APROBADOS AL TEORICO</div>
          <!-- Escape -->
          <div>
            <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px;">
              <span style="font-size:14px;font-weight:600;color:#fff;">Escape Autoescuelas</span>
              <span style="font-family:var(--font-display);font-size:32px;letter-spacing:-0.04em;color:var(--escape-red);">98%</span>
            </div>
            <div style="height:8px;border-radius:999px;background:rgba(255,255,255,0.08);overflow:hidden;">
              <div id="bar-escape-t" style="height:100%;border-radius:999px;background:var(--escape-red);width:0%;transition:width 1.6s cubic-bezier(0.22,1,0.36,1);"></div>
            </div>
          </div>
          <!-- Media -->
          <div>
            <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px;">
              <span style="font-size:14px;color:rgba(255,255,255,0.45);">Media nacional</span>
              <span style="font-family:var(--font-display);font-size:32px;letter-spacing:-0.04em;color:rgba(255,255,255,0.3);">73%</span>
            </div>
            <div style="height:8px;border-radius:999px;background:rgba(255,255,255,0.08);overflow:hidden;">
              <div id="bar-media-t" style="height:100%;border-radius:999px;background:rgba(255,255,255,0.2);width:0%;transition:width 1.6s cubic-bezier(0.22,1,0.36,1) 0.3s;"></div>
            </div>
          </div>
          <!-- Diferencia -->
          <div style="margin-top:8px;padding:20px 24px;border-radius:16px;background:rgba(200,16,46,0.15);border:1px solid rgba(200,16,46,0.25);">
            <div style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.15em;color:rgba(255,255,255,0.4);margin-bottom:6px;">DIFERENCIA</div>
            <div style="font-family:var(--font-display);font-size:40px;letter-spacing:-0.04em;color:#fff;">+25 <span style="font-size:0.5em;color:var(--escape-red);">puntos</span></div>
            <div style="font-size:13px;color:rgba(255,255,255,0.5);margin-top:4px;">por encima de la media nacional</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ LOS 4 PILARES ═══ -->
    <section id="pilares" style="padding:80px 56px;" data-c="pilaresSection">
      <div class="escape-reveal" style="margin-bottom:56px;display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:20px;">
        <div>
          <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.2em;color:var(--escape-red);margin-bottom:16px;display:flex;align-items:center;gap:10px;">
            <span style="width:20px;height:1px;background:var(--escape-red);display:inline-block;"></span>
            LOS 4 PILARES
          </div>
          <h2 style="font-family:var(--font-display);font-size:clamp(40px,6vw,88px);line-height:0.92;letter-spacing:-0.045em;margin:0;">
            El método que<br/><span class="escape-italic" style="color:var(--escape-red);">funciona.</span>
          </h2>
        </div>
        <div style="font-family:var(--font-display);font-size:clamp(48px,5vw,80px);letter-spacing:-0.05em;color:rgba(200,16,46,0.12);line-height:1;flex-shrink:0;">4</div>
      </div>

      <div class="pilares-grid escape-reveal-stagger">
        {pilares.map((p, i) => (
          <div class="pilar-card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px;">
              <span style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.18em;color:var(--escape-red);opacity:0.7;">{p.tag}</span>
              <span style="font-family:var(--font-display);font-size:clamp(56px,7vw,96px);line-height:1;letter-spacing:-0.05em;color:rgba(200,16,46,0.08);margin-top:-8px;">{p.n}</span>
            </div>
            <h3 style="font-family:var(--font-display);font-size:clamp(22px,2.5vw,36px);letter-spacing:-0.03em;line-height:1.05;margin:0 0 16px;">{p.t}</h3>
            <p style="font-size:15px;line-height:1.7;color:var(--escape-ink-2);margin:0;">{p.d}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ═══ EL PROCESO ═══ -->
    <section style="padding:80px 56px;background:var(--escape-paper-2);" data-c="procesoSection">
      <div class="escape-reveal" style="margin-bottom:56px;">
        <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.2em;color:var(--escape-red);margin-bottom:16px;display:flex;align-items:center;gap:10px;">
          <span style="width:20px;height:1px;background:var(--escape-red);display:inline-block;"></span>
          DE CERO A CARNET
        </div>
        <h2 style="font-family:var(--font-display);font-size:clamp(40px,6vw,80px);line-height:0.92;letter-spacing:-0.045em;margin:0;">
          4 pasos.<br/><span class="escape-italic" style="color:var(--escape-red);">Sin rodeos.</span>
        </h2>
      </div>

      <div class="proceso-grid escape-reveal-stagger" style="display:grid;grid-template-columns:repeat(4,1fr);gap:0;position:relative;">
        <!-- Linea conectora -->
        <div class="proceso-line" aria-hidden="true" style="position:absolute;top:36px;left:10%;right:10%;height:1px;background:linear-gradient(to right,var(--escape-red),rgba(200,16,46,0.2));pointer-events:none;z-index:0;"></div>

        {pasos.map((s, i) => (
          <div class="proceso-paso" style="padding:0 24px;position:relative;z-index:1;">
            <div style="width:72px;height:72px;border-radius:50%;background:var(--escape-red);display:flex;align-items:center;justify-content:center;margin-bottom:24px;flex-shrink:0;">
              <span style="font-family:var(--font-mono);font-size:13px;font-weight:700;color:#fff;letter-spacing:0.05em;">{s.n}</span>
            </div>
            <h3 style="font-family:var(--font-display);font-size:28px;letter-spacing:-0.03em;margin:0 0 10px;">{s.t}</h3>
            <p style="font-size:14px;line-height:1.6;color:var(--escape-ink-2);margin:0;">{s.d}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ═══ CTA FINAL ═══ -->
    <section class="escape-reveal" style="padding:80px 56px;" data-c="teoriaCta">
      <div style="background:var(--escape-ink);color:#fff;border-radius:24px;padding:64px 56px;display:grid;grid-template-columns:1fr auto;gap:48px;align-items:center;" class="teoria-cta-inner">
        <div>
          <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.18em;color:rgba(255,255,255,0.4);margin-bottom:14px;">EMPIEZA CUANDO QUIERAS</div>
          <h2 style="font-family:var(--font-display);font-size:clamp(36px,5vw,72px);line-height:0.92;letter-spacing:-0.04em;margin:0 0 16px;">
            El siguiente<br/><span class="escape-italic" style="color:var(--escape-red);">98%</span> eres tú.
          </h2>
          <p style="font-size:16px;color:rgba(255,255,255,0.55);margin:0;line-height:1.6;max-width:480px;">Matricúlate hoy y empieza con la plataforma esta misma tarde. Sin esperas, sin complicaciones.</p>
        </div>
        <div style="display:flex;flex-direction:column;gap:12px;flex-shrink:0;">
          <a href={siteConfig.whatsappUrl} target="_blank" rel="noopener"
            style="background:#25D366;color:#fff;padding:16px 28px;border-radius:999px;font-weight:700;font-size:15px;text-decoration:none;display:inline-flex;align-items:center;gap:10px;white-space:nowrap;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.15-.174.2-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
            WhatsApp ahora
          </a>
          <a href={siteConfig.phoneTel}
            style="background:rgba(255,255,255,0.08);color:#fff;border:1px solid rgba(255,255,255,0.15);padding:16px 28px;border-radius:999px;font-weight:600;font-size:15px;text-decoration:none;text-align:center;white-space:nowrap;">
            Llamar
          </a>
        </div>
      </div>
    </section>

    <style>
      /* Hero animations */
      .th-left  { animation: thLeft  0.9s cubic-bezier(0.22,1,0.36,1) both; }
      .th-right { animation: thRight 0.9s cubic-bezier(0.22,1,0.36,1) 0.15s both; }
      @keyframes thLeft  { from { opacity:0; transform:translateX(-24px); } to { opacity:1; transform:translateX(0); } }
      @keyframes thRight { from { opacity:0; transform:translateX(24px);  } to { opacity:1; transform:translateX(0); } }

      /* Pilares grid 2x2 */
      .pilares-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
        border: 1px solid var(--escape-line);
        border-radius: 20px;
        overflow: hidden;
      }
      .pilar-card {
        padding: 40px 36px;
        border-right: 1px solid var(--escape-line);
        border-bottom: 1px solid var(--escape-line);
        transition: background 0.3s;
        display: flex;
        flex-direction: column;
      }
      .pilar-card:hover { background: rgba(200,16,46,0.025); }
      .pilar-card:nth-child(2n) { border-right: none; }
      .pilar-card:nth-child(3),
      .pilar-card:nth-child(4) { border-bottom: none; }

      /* Proceso */
      .proceso-paso { animation: pasoIn 0.6s cubic-bezier(0.22,1,0.36,1) both; }
      .proceso-paso:nth-child(2) { animation-delay:0.1s; }
      .proceso-paso:nth-child(3) { animation-delay:0.2s; }
      .proceso-paso:nth-child(4) { animation-delay:0.3s; }
      @keyframes pasoIn { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }

      /* Responsive */
      @media (max-width: 1024px) {
        .teoria-hero-grid { grid-template-columns: 1fr !important; gap: 48px !important; }
        .th-right { display: none; }
      }
      @media (max-width: 900px) {
        [data-c="teoriaHero"]    { padding: 96px 24px 56px !important; min-height: unset !important; }
        [data-c="pilaresSection"]  { padding: 56px 24px !important; }
        .pilares-grid              { grid-template-columns: 1fr !important; border-radius: 16px; }
        .pilar-card                { padding: 28px 24px !important; border-right: none !important; border-bottom: 1px solid var(--escape-line) !important; }
        .pilar-card:last-child     { border-bottom: none !important; }
        [data-c="procesoSection"]{ padding: 56px 24px !important; }
        .proceso-grid            { grid-template-columns: 1fr 1fr !important; gap: 32px !important; }
        .proceso-line            { display: none; }
        .proceso-paso            { padding: 0 !important; }
        [data-c="teoriaCta"]     { padding: 48px 24px !important; }
        .teoria-cta-inner        { grid-template-columns: 1fr !important; padding: 36px 28px !important; gap: 28px !important; }
      }
      @media (max-width: 540px) {
        .proceso-grid { grid-template-columns: 1fr !important; }
      }
    </style>

    <script is:inline>
      (function() {
        var started = false;
        function easeOut(t) { return 1 - Math.pow(1 - t, 3); }

        function startHero() {
          if (started) return;
          started = true;

          // Count-up 98%
          var el = document.getElementById('teoria-counter');
          if (el) {
            var start = null;
            var duration = 1800;
            var target = 98;
            function step(ts) {
              if (!start) start = ts;
              var p = Math.min((ts - start) / duration, 1);
              el.textContent = Math.round(easeOut(p) * target);
              if (p < 1) requestAnimationFrame(step);
              else el.textContent = target;
            }
            requestAnimationFrame(step);
          }

          // Barras comparativa
          setTimeout(function() {
            var be = document.getElementById('bar-escape-t');
            var bm = document.getElementById('bar-media-t');
            if (be) be.style.width = '98%';
            if (bm) bm.style.width = '73%';
          }, 400);
        }

        var hero = document.querySelector('[data-c="teoriaHero"]');
        if (!hero) return;
        if ('IntersectionObserver' in window) {
          var obs = new IntersectionObserver(function(entries) {
            if (entries[0].isIntersecting) { startHero(); obs.disconnect(); }
          }, { threshold: 0.2 });
          obs.observe(hero);
        } else {
          startHero();
        }
      })();
    </script>

  </div>
</Layout>
